<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:arg name="use_gazebo" default="true"/>
  <xacro:arg name="use_wrist_camera" default="false"/>
  <xacro:arg name="prefix" default=""/>

  <xacro:if value="${'true' == '$(arg use_wrist_camera)' and 'true' == '$(arg use_gazebo)'}">

    <link name="$(arg prefix)camera_wrist_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.020 0.010 0.020"/>
        </geometry>
        <material name="DarkGrey">
          <color rgba="0.2 0.2 0.2 1"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.020 0.010 0.020"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.010"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
      </inertial>
    </link>

    <!--
      좌표계 (gripper_base 기준):
        +Y : 그리퍼 접근/파지 방향 (link6_flange +Z 와 동일)
        +Z : 그리퍼 위쪽 (finger 개폐 평면 수직)
        Gazebo camera 센서는 sensor link 의 +X 축을 바라봄

      배치 의도:
        xyz : 그리퍼 위쪽 35mm, link6_flange 보다 약간 앞쪽(Y -0.020)
        rpy : yaw 90도 로 카메라 +X 를 gripper_base +Y (접근 방향) 로 정렬
              pitch 20도(0.349) 로 파지 영역을 살짝 내려다 봄
    -->
    <joint name="$(arg prefix)gripper_base_to_$(arg prefix)camera_wrist" type="fixed">
      <parent link="$(arg prefix)gripper_base"/>
      <child link="$(arg prefix)camera_wrist_link"/>
      <origin xyz="0 0.020 0.035" rpy="0 0.349066 1.5707963"/>
    </joint>

    <!-- REP-103 광학 프레임: Z+ forward, X+ right, Y+ down -->
    <joint name="$(arg prefix)camera_wrist_optical_joint" type="fixed">
      <origin xyz="0 0 0" rpy="-1.5707963 0 -1.5707963"/>
      <parent link="$(arg prefix)camera_wrist_link"/>
      <child link="$(arg prefix)camera_wrist_optical_frame"/>
    </joint>
    <link name="$(arg prefix)camera_wrist_optical_frame"/>

    <gazebo reference="$(arg prefix)camera_wrist_link">
      <sensor name="camera_wrist" type="camera">
        <camera>
          <horizontal_fov>1.2217</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>RGB_INT8</format>
          </image>
          <clip>
            <near>0.02</near>
            <far>1.0</far>
          </clip>
        </camera>
        <always_on>1</always_on>
        <gz_frame_id>$(arg prefix)camera_wrist_optical_frame</gz_frame_id>
        <topic>camera_wrist/image</topic>
        <update_rate>10</update_rate>
        <visualize>true</visualize>
      </sensor>
    </gazebo>

  </xacro:if>
</robot>
