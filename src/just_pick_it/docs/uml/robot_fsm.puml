@startuml robot_fsm
title Just Pick It — Robot State Machines\nLayer B · robot.status 기준 · AMR은 role-mutable

' ============================================================
' 4 region: COBOT_SORTION / COBOT_INSPECTION / AMR_1 / AMR_2
' AMR_1, AMR_2 는 동형(homomorphic) region — task_type 가드로 분기
' Q1 결정 (UR/SR 부록 통합):
'   • role 컬럼 무관, IDLE 거리 우선 (동률 시 ns# 낮은 순)
'   • IDLE 없으면 큐 대기 → 가장 먼저 IDLE 회귀하는 AMR 픽업
' ============================================================

skinparam state {
  BackgroundColor<<idle>>     PaleGreen
  BorderColor<<idle>>         DarkGreen
  BackgroundColor<<work>>     LightYellow
  BorderColor<<work>>         DarkGoldenRod
  BackgroundColor<<move>>     LightCyan
  BorderColor<<move>>         SteelBlue
  BackgroundColor<<safe>>     Pink
  BorderColor<<safe>>         Crimson
  BackgroundColor<<error>>    Orange
  BorderColor<<error>>        DarkRed
  FontColor                   Black
}

' ── COBOT_SORTION (선별 상차 Cobot, SR_38) ───────────────────
state "COBOT_SORTION\nrole=SORTION" as COBOT_S {
  state "IDLE\n대기"          as CS_IDLE   <<idle>>
  state "ALIGNING\n주문 품목 섹션 시야 정렬\n(전지적 시점 · 해당 품목 다수 제품 한눈)" as CS_ALIGN  <<work>>
  state "DETECTING\n상품 인식" as CS_DETECT <<work>>
  state "GRIPPING\n그립 시도" as CS_GRIP   <<work>>
  state "PLACING\nAMR 상차"   as CS_PLACE  <<work>>
  state "ALT_TARGET\n후보 교체" as CS_ALT  <<work>>
  state "ERROR\n관리자 대기"   as CS_ERR   <<error>>

  [*]       --> CS_IDLE
  CS_IDLE   --> CS_ALIGN  : 상차 명령 수신\n(SR_29 / SR_37)
  CS_ALIGN  --> CS_DETECT : 시야 정렬 완료
  CS_DETECT --> CS_GRIP   : 대상 상품 선정\n(Yolo.v8, SR_33/SR_34)
  CS_GRIP   --> CS_PLACE  : 그립 성공\n(Moveit, SR_35/SR_36)
  CS_GRIP   --> CS_ALIGN  : 그립 실패 retry (≤2회)
  CS_GRIP   --> CS_ALT    : 그립 실패 3회
  CS_ALT    --> CS_ALIGN  : 후보 상품 존재
  CS_ALT    --> CS_ERR    : 후보 없음 (SR_48)
  CS_PLACE  --> CS_ALIGN  : 미상차 잔여
  CS_PLACE  --> CS_IDLE   : 전체 상차 완료\n→ Main Server 알림 (SR_37)
  CS_ERR    --> CS_IDLE   : 관리자 처리 완료
}

' ── COBOT_INSPECTION (검수 하차 Cobot, SR_39) ───────────────
state "COBOT_INSPECTION\nrole=INSPECTION" as COBOT_I {
  state "IDLE\n대기"                                   as CI_IDLE     <<idle>>
  state "INSPECTING\nAMR 픽업칸 일괄 검수\n(픽업칸 전체 한 시야 · 1회 매칭)" as CI_INSP <<work>>
  state "GRIPPING\n품목 그립"                          as CI_GRIP     <<work>>
  state "GRIP_ERROR\n그립 실패 알림\n(재시도 카운터)"  as CI_GRIP_ERR <<error>>
  state "PLACING\n픽업칸 하차"                         as CI_PLACE    <<work>>
  state "ERROR\n관리자 대기"                           as CI_ERR      <<error>>

  [*]         --> CI_IDLE
  CI_IDLE     --> CI_INSP     : 하차 명령 수신\n(SR_29 / SR_37)
  CI_INSP     --> CI_GRIP     : 구매 목록과 완전 일치\n(Yolo.v8, SR_33)
  CI_INSP     --> CI_ERR      : 누락·초과·오적재 감지 (SR_49)
  CI_GRIP     --> CI_PLACE    : 그립 성공\n(Moveit, SR_35/SR_36)
  CI_GRIP     --> CI_GRIP_ERR : 그립 실패\n→ ERROR 메시지 표시
  CI_GRIP_ERR --> CI_GRIP     : 재시도 (≤2회)
  CI_GRIP_ERR --> CI_ERR      : 3회 시도 모두 실패\n→ 관리자 호출
  CI_PLACE    --> CI_GRIP     : 다음 상품 잔여
  CI_PLACE    --> CI_IDLE     : 전체 하차 완료\n→ Main Server 알림 (SR_37)
  CI_ERR      --> CI_IDLE     : 관리자 처리 완료
}

' ── AMR_n (n ∈ {1,2}, role-mutable) ─────────────────────────
state "AMR_n  (n ∈ {1, 2})\n동형 region · task_type 분기" as AMR {
  state "IDLE\n대기 + 자동 충전 @ Standby" as A_IDLE    <<idle>>
  state "MOVING\n이동 중"                as A_MOVING  <<move>>
  state "AT_LOADING\nLoading 정지"        as A_LOAD    <<work>>
  state "DELIVERING\n상품 운반"           as A_DELIV   <<work>>
  state "AT_UNLOADING\nUnloading 정지"    as A_UNLOAD  <<work>>
  state "PATROLLING\n순찰 + 비전 감지"    as A_PATROL  <<work>>
  state "REPORTING\n순찰 결과 보고"       as A_REPORT  <<work>>
  state "RETURNING\nStandby 복귀"          as A_RETURN  <<move>>
  state "ERROR\n관리자 대기"               as A_ERR     <<error>>
  state "OFFLINE\n연결 끊김"               as A_OFF     <<error>>

  [*]      --> A_IDLE
  A_IDLE   --> A_MOVING : [task=DELIVERY]\nLoading 향해 출발 (SR_26/SR_27)
  A_IDLE   --> A_MOVING : [task=PATROL]\n순찰 zone 향해 출발 (SR_30)

  ' --- DELIVERY 분기 ---
  A_MOVING --> A_LOAD   : [task=DELIVERY]\nLoading 도착·등지고 정지 (SR_28)
  A_LOAD   --> A_DELIV  : COBOT_SORTION 상차 완료 (SR_37)
  A_DELIV  --> A_UNLOAD : Unloading 도착·정지 (SR_29)
  A_UNLOAD --> A_RETURN : COBOT_INSPECTION 하차 완료 (SR_37)

  ' --- PATROL 분기 ---
  A_MOVING --> A_PATROL : [task=PATROL]\n순찰 zone 도착 (SR_30)
  A_PATROL --> A_REPORT : 순찰 종료 (SR_32)
  A_PATROL --> A_REPORT : 비상 감지·즉시 보고 (SR_31, SR_47)
  A_REPORT --> A_RETURN : Standby 복귀 명령

  ' --- 복귀 (공통) — IDLE @ Standby = 자동 충전 동시 진행 ---
  A_RETURN --> A_IDLE   : Standby 도착\n→ Dock 안착 + 자동 충전 (SR_41~SR_43)

  ' --- 회피 / 예외 ---
  A_MOVING --> A_MOVING : 장애물 감지 → 경로 재탐색 (SR_27)
  A_DELIV  --> A_ERR    : 운반 중 오류
  A_PATROL --> A_ERR    : 비전 시스템 오류
  A_ERR    --> A_IDLE   : 관리자 처리 완료
  A_OFF    --> A_IDLE   : 연결 복구
}

' ── 글로벌 SAFETY_STOP (SR_44~SR_46) ────────────────────────
state "SAFETY_STOP\n[전역 일시 정지]" as SAFETY <<safe>>

COBOT_S -[#red]-> SAFETY  : 사람 감지 (any camera, SR_44)
COBOT_I -[#red]-> SAFETY
AMR     -[#red]-> SAFETY
SAFETY  -[#green]-> COBOT_S : 관리자 재개 (SR_45/SR_46)
SAFETY  -[#green]-> COBOT_I
SAFETY  -[#green]-> AMR

note right of AMR
  Q1 결정 (UR/SR 부록 통합):
   • AMR_1, AMR_2 는 role 무관, task_type 으로 동적 분기
   • PATROL 명령 시 IDLE 거리 우선 (동률 시 ns# 낮은 순)
   • IDLE AMR 없으면 task 큐 대기 →
     가장 먼저 IDLE 회귀하는 AMR 자동 픽업
   • "Transport 끝나고 Patrol" 의 자연 표현
end note

@enduml
