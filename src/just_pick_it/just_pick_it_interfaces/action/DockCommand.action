# PICKY State Manager가 수행하는 로컬 도킹 명령

# Goal: ArUco/라인 기반 도킹에 필요한 최소 정보
int32 task_id
string dock_name          # TrafficManager가 예약한 논리 도크 이름. 예: CHARGING_DOCK_1
string start_zone_name    # 라인/ArUco 도킹을 시작하는 STANDBY_ZONE 이름
---
# Result
bool success
string message
---
# Feedback
string phase
float32 progress
string message
