# Task Manager가 Cobot State Manager에게 작업 명령을 전달하는 Action

# Goal
string task_id
string task_type        # SORTING_AND_LOAD / INSPECTION / UNLOAD / DISPLAY_SCAN / DISPLAY_PLACE
string robot_name
string[] item_types     # 집어야 할 상품군 목록 (예: ["수박", "생수"])
int32[] item_quantities # item_types 와 동일 인덱스 기준 각 상품 수량 (예: [2, 1])
---
# Result
bool success
string status        # SUCCESS / FAILED / CANCELLED
string message
int32 detected_quantity
int32 stock_delta
---
# Feedback
string state
string message
float32 progress          # 0.0 ~ 1.0
int32 detected_quantity
string current_item_type  # 현재 작업 중인 상품군 (예: "수박")
int32 current_item_index  # 현재 상품군의 몇 번째 (1-based, 예: 수박 2개 중 1번째이면 1)
