<?xml version='1.0' ?>

<launch>
    <!-- Robot -->
    <arg name="namespace"     default=""/>
    <arg name="robot_name"    default="$(var namespace)pinky"/>
    <arg name="cam_tilt_deg"  default="0"/>
    <arg name="world_name"    default="box_arena.world"/>
    <arg name="world"         default="$(find-pkg-share pinky_gz_sim)/worlds/$(var world_name)"/>
    <arg name="bridge_params" default="$(find-pkg-share pinky_gz_sim)/params/pinky_bridge.yaml"/>

    <!-- GZ_SIM_RESOURCE_PATH: pinky models + just_pick_it_simulation models -->
    <set_env name="GZ_SIM_RESOURCE_PATH"
             value="$(find-pkg-share pinky_description)/../:$(find-pkg-share pinky_gz_sim)/models:$(find-pkg-share just_pick_it_simulation)/models:$(env HOME)/.gazebo/models"/>

    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name='gz_args'          value='-r -s -v4, $(var world)'/>
        <arg name='on_exit_shutdown' value='true'/>
    </include>

    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name='gz_args' value='-g -v4 '/>
    </include>

    <include file="$(find-pkg-share pinky_description)/launch/upload_robot.launch.py">
        <arg name='namespace'    value='$(var namespace)'/>
        <arg name='use_sim_time' value='True'/>
        <arg name='is_sim'       value='True'/>
        <arg name='cam_tilt_deg' value='$(var cam_tilt_deg)'/>
    </include>

    <!-- Spawn robot at arena center, 10 cm above floor -->
    <node pkg="ros_gz_sim" exec="create" name='create' output='screen'
          args="-name $(var robot_name) -topic $(var namespace)/robot_description -x 0.0 -y 0.0 -z 0.1">
        <param name='use_sim_time' value='True'/>
    </node>

    <!-- Checkerboard spawn pose: x y z roll pitch yaw (metres, radians) -->
    <arg name="cb_x"   default="0.73"/>
    <arg name="cb_y"   default="0.0"/>
    <arg name="cb_z"   default="0.2"/>
    <arg name="cb_R"   default="0.0"/>
    <arg name="cb_P"   default="0.0"/>
    <arg name="cb_Y"   default="0.0"/>

    <!-- Spawn 8x6 inner-corner checkerboard (9x7 squares, 25mm square size) -->
    <node pkg="ros_gz_sim" exec="create" name='create_checkerboard' output='screen'
          args="-name checkerboard_8x6 -file $(find-pkg-share just_pick_it_simulation)/models/markers/checkerboard_8x6/model.sdf -x $(var cb_x) -y $(var cb_y) -z $(var cb_z) -R $(var cb_R) -P $(var cb_P) -Y $(var cb_Y)">
        <param name='use_sim_time' value='True'/>
    </node>

    <node pkg="ros_gz_bridge" exec="parameter_bridge" name='parameter_bridge' output='screen'
          args="--ros-args -p config_file:=$(var bridge_params)"/>
    <node pkg="ros_gz_image" exec="image_bridge" name='image_bridge'       output='screen' args="/camera/image_raw"/>
    <node pkg="ros_gz_image" exec="image_bridge" name='image_bridge_depth' output='screen' args="/camera"/>

</launch>
