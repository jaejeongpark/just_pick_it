          <diffuse>0.85 0.85 0.83 1</diffuse>
          <specular>0.6 0.6 0.6 1</specular>
        </material>
      </visual>

      <!-- 외접 충돌 박스 (캔 묶음 전체 bounding box) -->
      <collision name="collision">
        <geometry>
          <box>
            <size>0.050 0.0334 0.029</size>
          </box>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.6</mu>
              <mu2>0.6</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>
