        </geometry>
        <material>
          <ambient>0.82 0.82 0.80 1</ambient>
          <diffuse>0.85 0.85 0.83 1</diffuse>
          <specular>0.6 0.6 0.6 1</specular>
        </material>
      </visual>

      <visual name="can_top_5">
        <pose>0.0 0.00835 0.01425 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.0079</radius>
            <length>0.0008</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.82 0.82 0.80 1</ambient>
          <diffuse>0.85 0.85 0.83 1</diffuse>
          <specular>0.6 0.6 0.6 1</specular>
        </material>
      </visual>

