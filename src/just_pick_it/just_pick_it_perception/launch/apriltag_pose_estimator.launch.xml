<?xml version='1.0' ?>

<launch>
    <arg name="calibration_file"  default="$(env HOME)/just_pick_it/src/just_pick_it/just_pick_it_perception/result/camera_calibration.yaml"/>
    <arg name="tag_db_file"       default=""/>
    <arg name="use_camera_info"   default="false"/>
    <arg name="image_topic"       default="/camera/image_raw"/>
    <arg name="camera_info_topic" default="/camera/camera_info"/>
    <arg name="world_frame"       default="map"/>
    <arg name="base_frame"        default="base_footprint"/>
    <arg name="pose_topic"        default="/robot_pose"/>
    <arg name="target_group"      default=""/>
    <arg name="use_sim_time"      default="true"/>

    <node pkg="just_pick_it_perception" exec="apriltag_detector"
          name="apriltag_detector" output="screen">
        <param name="calibration_file"  value="$(var calibration_file)"/>
        <param name="image_topic"       value="$(var image_topic)"/>
        <param name="annotated_topic"    value="/apriltag/image_annotated"/>
    </node>
</launch>
