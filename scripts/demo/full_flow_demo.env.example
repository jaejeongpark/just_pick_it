# scripts/demo/full_flow_demo.env로 복사한 뒤 DEMO_ROS_DOMAIN_ID를 채운다.

# Fleet Manager와 가짜 로봇 서버가 같이 사용할 ROS 도메인 ID.
export DEMO_ROS_DOMAIN_ID=25

# =====================================
# 가짜 PICKY
# =====================================

# true면 fake PICKY action/state/battery/pose 서버를 띄운다.
# 실제 PICKY 보드와 같이 테스트할 때는 false로 둔다.
export DEMO_MOCK_PICKY=true

# PICKY1 Nav2 일반 이동 속도(m/s).
export DEMO_PICKY_LINEAR_SPEED_MPS=0.20

# Fleet/Web 표시용 가짜 PICKY 위치 발행 빈도(Hz).
export DEMO_PICKY_POSE_HZ=1.0

# PICKY1 도크 이탈/후진 도킹 속도(m/s).
export DEMO_DOCK_LINEAR_SPEED_MPS=0.05

# 충전 중 이 값(%)을 넘으면 CHARGING -> STANDBY로 전환.
export DEMO_PICKY_BATTERY_STANDBY_THRESHOLD=30.0

# 주문/진열 한 흐름이 끝날 때마다 차감할 배터리(%).
export DEMO_PICKY_BATTERY_DRAIN_PER_FLOW=0.0

# 도킹 뒤 100%까지 충전되는 데 걸리는 시간(초).
export DEMO_PICKY_CHARGE_COMPLETE_SECONDS=5.0

# PICKY/COBOT 상태 주기 발행 간격(초).
export DEMO_STATE_PUBLISH_INTERVAL_SECONDS=1.0

# =====================================
# 가짜 COBOT
# =====================================

# true면 fake COBOT action/state 서버를 띄운다.
export DEMO_MOCK_COBOT=true

# 주문 상품 탐색/선별 단계 시간(초).
export DEMO_COBOT_SORTING_SECONDS=1.0

# PICKY 상차 단계 시간(초).
export DEMO_COBOT_LOADING_SECONDS=1.0

# 주문 상품 검수 단계 시간(초).
export DEMO_COBOT_INSPECTING_SECONDS=1.0

# 픽업 슬롯 하차 단계 시간(초).
export DEMO_COBOT_UNLOADING_SECONDS=1.0

# 진열 위치 탐색 단계 시간(초).
export DEMO_COBOT_SCANNING_SECONDS=1.0

# 진열대 배치 단계 시간(초).
export DEMO_COBOT_PLACING_SECONDS=1.0

# 팔 기본 자세 복귀 단계 시간(초).
export DEMO_COBOT_STOWING_ARM_SECONDS=1.0

# true면 fake COBOT이 자동으로 result를 반환한다.
# false면 goal만 받아 RUNNING 상태로 두고 debug curl로 완료 처리한다.
export DEMO_COBOT_AUTO_COMPLETE=true
