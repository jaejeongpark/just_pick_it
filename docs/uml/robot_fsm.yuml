@startuml robot_fsm
title Just Pick It — Robot State Machines

skinparam state {
  BackgroundColor LightYellow
  BorderColor DarkOrange
}

' ── Pinky A (상하차 AMR) ─────────────────────────────────────
state "Pinky A  [상하차 AMR]" as PinkyA {
  [*] --> PA_Idle
  PA_Idle     --> PA_Charging       : 주문 없음 + 배터리 < 충전 임계값
  PA_Charging --> PA_Idle           : 충전 완료 / 주문 수신
  PA_Idle     --> PA_ToLoading      : 배차 명령 수신
  PA_ToLoading      --> PA_AtLoading      : Loading Zone 도착·정지
  PA_AtLoading      --> PA_ToUnloading    : 상차 완료 수신 (Jetcobot A 알림)
  PA_ToUnloading    --> PA_AtUnloading    : Unloading Zone 도착·정지
  PA_AtUnloading    --> PA_ToStandby     : 하차 완료 수신 (Jetcobot B 알림)
  PA_ToStandby --> PA_Charging : 배터리 < 20 %
  PA_ToStandby --> PA_Idle     : 배터리 ≥ 20 %
}

' ── Pinky B (순찰 AMR) ──────────────────────────────────────
state "Pinky B  [순찰 AMR]" as PinkyB {
  [*] --> PB_Idle
  PB_Idle       --> PB_Charging   : 명령 없음
  PB_Charging   --> PB_Idle       : 관리자 명령 수신
  PB_Idle       --> PB_Patrolling : 자연어 명령 → LLM → 액션 매핑 (SR_N2)
  PB_Patrolling --> PB_Reporting  : 순찰 완료 (감지 결과 포함)
  PB_Reporting  --> PB_Idle       : 보고 완료 → Standby Zone 복귀
}

' ── Jetcobot A (선별 상차 암) ────────────────────────────────
state "Jetcobot A  [선별 상차]" as JetcobotA {
  [*] --> JA_Idle
  JA_Idle      --> JA_Aligning  : 상차 명령 수신
  JA_Aligning  --> JA_Detecting : Align 완료
  JA_Detecting --> JA_Gripping  : 상품 선정
  JA_Gripping  --> JA_Placing   : 그립 성공
  JA_Gripping  --> JA_Aligning  : 그립 실패 retry (≤2회)
  JA_Gripping  --> JA_AltTarget : 그립 실패 3회
  JA_AltTarget --> JA_Aligning  : 후보 상품 존재
  JA_AltTarget --> JA_Error     : 후보 없음
  JA_Placing   --> JA_Aligning  : 다음 상품 잔여
  JA_Placing   --> JA_Idle      : 전체 상차 완료 → Main Server 알림
  JA_Error     --> JA_Idle      : 관리자 처리 완료
}

' ── Jetcobot B (검수 하차 암) ────────────────────────────────
state "Jetcobot B  [검수 하차]" as JetcobotB {
  [*] --> JB_Idle
  JB_Idle       --> JB_Inspecting : 하차 명령 수신
  JB_Inspecting --> JB_Placing    : 검수 통과
  JB_Inspecting --> JB_Error      : 누락·초과·오적재
  JB_Placing    --> JB_Inspecting : 다음 상품 잔여
  JB_Placing    --> JB_Idle       : 전체 하차 완료 → Main Server 알림
  JB_Error      --> JB_Idle       : 관리자 처리 완료
}

' ── 공통 SAFETY_STOP ─────────────────────────────────────────
state "SAFETY_STOP\n[전역 일시 정지]" as SafetyStop #Pink

PinkyA    -[#red]-> SafetyStop : 사람 감지 (any camera)
PinkyB    -[#red]-> SafetyStop
JetcobotA -[#red]-> SafetyStop
JetcobotB -[#red]-> SafetyStop

SafetyStop -[#green]-> PinkyA    : 관리자 재개 승인
SafetyStop -[#green]-> PinkyB
SafetyStop -[#green]-> JetcobotA
SafetyStop -[#green]-> JetcobotB

@enduml